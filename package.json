{
  "name": "nexusai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev", 
    "build": "next build --webpack", 
    "start": "next start",
    "lint": "eslint app components hooks lib types *.mjs",
    "lint:fix": "eslint app components hooks lib types *.mjs --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs}\" --ignore-path .gitignore",
    "typecheck": "tsc --noEmit",
    "prepare": "husky install",
    "test": "npm run test:agent && npm run test:agent-progress && npm run test:behavior-upgrade && npm run test:retry && npm run test:puter-service && npm run test:chat-storage && npm run test:orchestration && npm run test:nexus-core-integration && npm run test:ai-routing && npm run test:media-assets && npm run test:video-generation && npm run test:brand-identity && npm run test:provider-credentials && npm run test:upload-worker && npm run test:publishing-readiness && npm run test:server-ai-proxy && npm run test:new-api-endpoints",
    "test:agent": "node --eval \"import('./tests/agent-behavior.test.mjs')\"",
    "test:agent-progress": "node --eval \"import('./tests/agent-progress.test.mjs')\"",
    "test:behavior-upgrade": "node --eval \"import('./tests/behavior-upgrade.test.mjs')\"",
    "test:retry": "node --eval \"import('./tests/retry.test.mjs')\"",
    "test:puter-service": "node --eval \"import('./tests/puter-service.test.mjs')\"",
    "test:chat-storage": "node --eval \"import('./tests/chat-storage-sanitization.test.mjs')\"",
    "test:nexus-core-integration": "node --eval \"import('./tests/nexus-core-integration.test.mjs')\"",
    "test:orchestration": "node --eval \"import('./tests/orchestration-pipeline.test.mjs')\"",
    "test:ai-routing": "node --eval \"import('./tests/ai-routing.test.mjs')\"",
    "test:media-assets": "node --eval \"import('./tests/media-asset-primitives.test.mjs')\"",
    "test:video-generation": "node --eval \"import('./tests/video-generation.test.mjs')\"",
    "test:brand-identity": "node --eval \"import('./tests/brand-identity-parser.test.mjs')\"",
    "test:provider-credentials": "node --eval \"import('./tests/provider-credentials.test.mjs')\"",
    "test:upload-worker": "node --eval \"import('./tests/upload-worker.test.mjs')\"",
    "test:publishing-readiness": "node --eval \"import('./tests/publishing-readiness.test.mjs')\"",
    "test:server-ai-proxy": "node --eval \"import('./tests/server-ai-provider-proxy.test.mjs')\"",
    "test:new-api-endpoints": "node --test tests/new-api-endpoints.test.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "yjs": "^13.6.10",
    "y-websocket": "^1.5.0",
    "@next/swc-wasm-nodejs": "16.2.0",
    "@next/swc-wasm-web": "16.2.0",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-aspect-ratio": "1.1.8",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-menubar": "1.1.16",
    "@radix-ui/react-navigation-menu": "1.2.14",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-toggle": "1.1.10",
    "@radix-ui/react-toggle-group": "1.1.11",
    "@radix-ui/react-tooltip": "1.2.8",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.57.4",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@vercel/analytics": "1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.1.0",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "lucide-react": "^0.564.0",
    "mammoth": "^1.8.0",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
    "papaparse": "^5.4.1",
    "pdfjs-dist": "^4.0.0",
    "react": "19.2.4",
    "react-day-picker": "9.13.2",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.1",
    "react-resizable-panels": "^2.1.7",
    "recharts": "2.15.0",
    "sonner": "^1.7.1",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^22",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "postcss": "^8.5",
    "prettier": "^3.3.0",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "1.3.3",
    "typescript": "5.7.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": ["eslint --fix", "prettier --write"],
    "*.{json,md,yml,yaml}": "prettier --write"
  }
}
