{
  "name": "nexusai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components hooks lib types *.mjs",
    "lint:fix": "eslint app components hooks lib types *.mjs --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs}\" --ignore-path .gitignore",
    "typecheck": "tsc --noEmit",
    "prepare": "husky || true",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:agent": "vitest run agent-behavior.test.mjs agent-progress.test.mjs",
    "test:orchestration": "vitest run orchestration-pipeline.test.mjs",
    "test:nexus-core-integration": "vitest run nexus-core-integration.test.mjs",
    "test:ai-routing": "vitest run ai-routing.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "android": "npx cap open android",
    "sync:android": "npx cap copy android",
    "build:android": "npx cap copy android && npx cap open android",
    "dev:android": "npm run dev & npx cap open android",
    "collab": "node collaboration-server.mjs",
    "collab:dev": "tsx collaboration-server.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@hookform/resolvers": "^3.9.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-menubar": "1.1.16",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-toggle": "1.1.10",
    "@radix-ui/react-tooltip": "1.2.8",
    "@sentry/nextjs": "^9.47.1",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.57.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.564.0",
    "mammoth": "^1.8.0",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
    "papaparse": "^5.4.1",
    "pdfjs-dist": "^4.0.0",
    "react": "19.2.4",
    "react-day-picker": "9.13.2",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.1",
    "react-resizable-panels": "^2.1.7",
    "recharts": "2.15.0",
    "sonner": "^1.7.1",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.3.1",
    "y-websocket": "^1.5.0",
    "yjs": "^13.6.10",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^22",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.2.0",
    "postcss": "^8.5",
    "prettier": "^3.3.0",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "1.3.3",
    "typescript": "5.7.3",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": "prettier --write"
  }
}
