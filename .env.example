# ===========================================
# NEXUSAI ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ===========================================
# SUPABASE (Required for auth)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key  # Usually same as anon key for client-side
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# PUTER (Default AI - no key needed)
# ===========================================
NEXT_PUBLIC_PUTER_DOMAIN=puter.app
NEXT_PUBLIC_PUTER_BASE_PATH=/NexusAI

# ===========================================
# AI PROVIDERS (Optional - at least one required for content generation)
# ===========================================
# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic/Claude
ANTHROPIC_API_KEY=sk-ant-...

# Groq (fast inference)
GROQ_API_KEY=gsk_...

# Gemini (Google)
GEMINI_API_KEY=AIza...

# ===========================================
# MEDIA PROVIDERS (Optional)
# ===========================================
# ElevenLabs (Voice generation)
ELEVENLABS_API_KEY=your-key
# ELEVENLABS_VOICE_ID is not used (voice hardcoded to 'alloy'), but kept for reference
# ELEVENLABS_VOICE_ID=your-voice-id

# Suno AI (Music generation)
SUNO_API_KEY=your-key

# Musicfy (Free tier available)
MUSICFY_API_KEY=your-key

# Beatoven (Free 15 mins/mo)
BEATOVEN_API_KEY=your-key

# AIVA (Free tier available)
AIVA_API_KEY=your-key

# HuggingFace (For Dadabots and Jukebox)
HUGGINGFACE_API_KEY=your-key

# Azure Cognitive Services (Voice - 500K chars/mo free)
AZURE_SPEECH_KEY=your-key
AZURE_SPEECH_REGION=eastus

# LTX Video (Video generation) - via Fal.ai
LTX_API_KEY=your-key
FAL_API_KEY=your-key

# Speechify (Voice - 10K chars/mo free) - Not currently integrated
# SPEECHIFY_API_KEY=your-key

# ===========================================
# IMAGE GENERATION
# ===========================================
# OpenAI DALL-E (uses OPENAI_API_KEY above)
# Replicate (for Stable Diffusion, etc.)
REPLICATE_API_KEY=your-token
# Stability AI
STABILITY_API_KEY=your-stability-key
# Ideogram
IDEOGRAM_API_KEY=your-ideogram-key

# ===========================================
# EXTERNAL APIS (Optional)
# ===========================================
# MediaStack (News aggregation)
MEDIASTACK_API_KEY=your-mediastack-key
# SERPStack (Search engine results)
SERPSTACK_API_KEY=your-serpstack-key
# IPStack (Geolocation) — auto-detects user region for compliance filtering
IPSTACK_API_KEY=your-ipstack-key

# ===========================================
# AUTOMATION (Optional)
# ===========================================
# N8N Workflow
N8N_URL=http://localhost
N8N_PORT=5678
N8N_API_KEY=your-key
N8N_BRIDGE_SECRET=your-secret
N8N_HOST=http://localhost  # Used in n8nBridgeService

# ===========================================
# MONITORING & ANALYTICS
# ===========================================
# Sentry (Error tracking)
SENTRY_DSN=your-dsn
# SENTRY_AUTH_TOKEN is not used (only DSN needed), but kept for reference
# SENTRY_AUTH_TOKEN=your-token

# ===========================================
# API URL OVERRIDES (Optional)
# ===========================================
# These allow overriding the default API URLs for each provider.
# Only needed if you use self-hosted or custom API endpoints.
NEXT_PUBLIC_GROQ_URL=https://api.groq.com
NEXT_PUBLIC_OPENROUTER_URL=https://openrouter.ai
NEXT_PUBLIC_NVIDIA_URL=https://integrate.api.nvidia.com
NEXT_PUBLIC_TOGETHER_URL=https://api.together.xyz
NEXT_PUBLIC_FIREWORKS_URL=https://api.fireworks.ai
NEXT_PUBLIC_DEEPSEEK_URL=https://api.deepseek.com
NEXT_PUBLIC_OLLAMA_URL=http://localhost:11434
NEXT_PUBLIC_GITHUB_MODELS_URL=https://models.github.ai
NEXT_PUBLIC_BYTEZ_URL=https://api.bytez.com
NEXT_PUBLIC_POE_URL=https://api.poe.com
NEXT_PUBLIC_STABILITY_URL=https://api.stability.ai
NEXT_PUBLIC_LEONARDO_URL=https://api.leonardo.ai
NEXT_PUBLIC_IDEOGRAM_URL=https://api.ideogram.ai
NEXT_PUBLIC_ELEVENLABS_URL=https://api.elevenlabs.io
NEXT_PUBLIC_SPEECHIFY_URL=https://api.speechify.com
NEXT_PUBLIC_PLAYHT_URL=https://api.play.ht
NEXT_PUBLIC_RESEMBLE_URL=https://api.resemble.ai
NEXT_PUBLIC_SUNO_URL=https://api.suno.ai
NEXT_PUBLIC_UDIO_URL=https://api.udio.ai
NEXT_PUBLIC_BEATOVEN_URL=https://api.beatoven.ai
NEXT_PUBLIC_SOUNDRAW_URL=https://api.soundraw.io
NEXT_PUBLIC_AYRSHARE_URL=https://app.ayrshare.com/api

# ===========================================
# E-COMMERCE PUBLISHING (Optional)
# ===========================================
# Shopify (Shopify store publishing)
SHOPIFY_STORE_URL=https://your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=gpos_...

# Amazon Product Selling API (SP-API with AWS SigV4)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# Amazon PA-API (Product Advertising API) for product search
AMAZON_PA_API_KEY=your-pa-api-key
AMAZON_PA_SECRET_KEY=your-pa-api-secret-key
AMAZON_ASSOCIATE_TAG=your-tag-20
AMAZON_PA_REGION=us-east-1
AMAZON_SELLER_ID=ATVPDKIKX0DER
# SP-API OAuth (optional - for programmatic access tokens)
# AMAZON_SP_API_REFRESH_TOKEN=your-refresh-token
# AMAZON_SP_API_CLIENT_ID=your-client-id
# AMAZON_SP_API_CLIENT_SECRET=your-client-secret

# Etsy
ETSY_API_KEY=your-etsy-api-key
ETSY_SHOP_ID=your-shop-id

# ===========================================
# SOCIAL PLATFORMS (Native Publishing)
# ===========================================
# Twitter/X
TWITTER_API_KEY=your-twitter-key
TWITTER_API_SECRET=your-twitter-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret

# Instagram (Meta Graph API)
INSTAGRAM_BUSINESS_ACCOUNT_ID=your-account-id
INSTAGRAM_ACCESS_TOKEN=your-instagram-token

# LinkedIn
LINKEDIN_API_KEY=your-linkedin-key
LINKEDIN_SECRET=your-linkedin-secret
LINKEDIN_ACCESS_TOKEN=your-linkedin-token

# Facebook
FACEBOOK_API_KEY=your-facebook-key
FACEBOOK_SECRET=your-facebook-secret
FACEBOOK_PAGE_TOKEN=your-page-token

# TikTok
TIKTOK_API_KEY=your-tiktok-key
TIKTOK_SECRET=your-tiktok-secret

# Reddit
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_ACCESS_TOKEN=your-reddit-access-token

# WhatsApp (Meta Graph API)
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_ID=your-phone-id

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Snapchat
SNAPCHAT_ACCESS_TOKEN=your-snapchat-token

# ===========================================
# EMAIL MARKETING (Optional)
# ===========================================
# Mailchimp
MAILCHIMP_API_KEY=your-mailchimp-api-key-us19
MAILCHIMP_LIST_ID=your-list-id
MAILCHIMP_SERVER_PREFIX=us19

# Klaviyo (Campaign creation with template mapping)
KLAVIYO_API_KEY=your-klaviyo-key
KLAVIYO_TEMPLATE_ID=your-template-id
KLAVIYO_LIST_ID=your-list-id

# ConvertKit
CONVERTKIT_API_KEY=your-convertkit-key

# ===========================================
# BLOGGING PLATFORMS (Optional)
# ===========================================
# WordPress
WORDPRESS_API_URL=https://your-site.com
WORDPRESS_USERNAME=your-username
WORDPRESS_APPLICATION_PASSWORD=your-app-password

# Medium
MEDIUM_INTEGRATION_TOKEN=your-medium-token
MEDIUM_USER_ID=your-user-id

# Ghost
GHOST_API_URL=https://your-ghost-site.com
GHOST_ADMIN_API_KEY=id:secret

# Substack (Multi-method: N8N webhook, email, or third-party API)
SUBSTACK_API_KEY=your-substack-key
SUBSTACK_NEWSLETTER_ID=your-newsletter-id
# Method 1: N8N webhook bridge
# SUBSTACK_N8N_WEBHOOK=https://your-n8n.com/webhook/substack-publish
# Method 2: Email-based (SendGrid or SMTP)
# SUBSTACK_EMAIL=publish@substack.com
# SUBSTACK_SMTP_HOST=smtp.sendgrid.net
# SUBSTACK_SMTP_USER=apikey
# SUBSTACK_SMTP_PASS=your-sendgrid-key

# ===========================================
# COMPLIANCE & SECURITY
# ===========================================
CONTENT_FILTER_REGIONS=us,eu,ca,au,jp,cn,in,de,fr,es

# ===========================================
# WEBHOOK SECURITY
# ===========================================
WEBHOOK_SECRET_TOKEN=your-webhook-secret  # REQUIRED if using webhooks

# ===========================================
# COLLABORATION (Multi-provider: y-websocket + Supabase Realtime fallback)
# Dedicated y-websocket server (recommended for production)
NEXT_PUBLIC_COLLAB_SERVER=wss://your-collab-server.com:1234
# Collaboration mode: 'auto' (try y-websocket, fallback Supabase), 'supabase', 'local'
NEXT_PUBLIC_COLLAB_MODE=auto

# ===========================================
# WORKER & BACKGROUND JOBS
# ===========================================
# WORKER_SECRET=<generate a random secret>

# ===========================================
# STRIPE (Optional - for monetization)
# ===========================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ===========================================
# PUTER (Optional overrides)
# ===========================================
# NEXT_PUBLIC_PUTER_APP_ID=your-puter-app-id

# ===========================================
# N8N ENCRYPTION (Optional)
# ===========================================
# N8N_ENCRYPTION_KEY=<generate a random key>

# ===========================================
# LOGGING (Optional)
# ===========================================
# LOG_LEVEL=info
# BLACKBOARD_TRACE=false

# ===========================================
# SITE URL (Required for OG images)
# ===========================================
# NEXT_PUBLIC_SITE_URL=https://your-domain.com  # Required for OG images; set to your production URL

# ===========================================
# SECURITY (Recommended for production)
# ===========================================
# ALLOWED_PROXY_ORIGINS=https://your-domain.com,https://app.your-domain.com  # CORS for proxy endpoint
# HEALTH_CHECK_PUBLIC=false  # Set to 'true' to expose detailed health check info publicly