# ===========================================
# NEXUSAI ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ===========================================
# SUPABASE (Required for auth)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# PUTER (Default AI - no key needed)
# ===========================================
NEXT_PUBLIC_PUTER_DOMAIN=puter.app

# ===========================================
# AI PROVIDERS (Optional - at least one required for content generation)
# ===========================================
# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic/Claude
ANTHROPIC_API_KEY=sk-ant-...

# Groq (fast inference)
GROQ_API_KEY=gsk_...

# Gemini (Google)
GEMINI_API_KEY=AIza...

# ===========================================
# MEDIA PROVIDERS (Optional)
# ===========================================
# ElevenLabs (Voice generation)
ELEVENLABS_API_KEY=your-key
ELEVENLABS_VOICE_ID=your-voice-id

# Suno AI (Music generation)
SUNO_API_KEY=your-key
SUNO_API_SECRET=your-secret

# Azure Cognitive Services (Voice - 500K chars/mo free)
AZURE_SPEECH_KEY=your-key
AZURE_SPEECH_REGION=eastus

# LTX Video (Video generation)
LTX_API_KEY=your-key

# Speechify (Voice - 10K chars/mo free)
SPEECHIFY_API_KEY=your-key

# ===========================================
# IMAGE GENERATION
# ===========================================
# OpenAI DALL-E
OPENAI_API_KEY=sk-...  # Already listed above

# Replicate (for Stable Diffusion, etc.)
REPLICATE_API_TOKEN=your-token

# ===========================================
# AUTOMATION (Optional)
# ===========================================
# N8N Workflow
N8N_URL=http://localhost
N8N_PORT=5678
N8N_API_KEY=your-key
N8N_BRIDGE_SECRET=your-secret

# ===========================================
# MONITORING & ANALYTICS
# ===========================================
# Sentry (Error tracking)
SENTRY_DSN=your-dsn
SENTRY_AUTH_TOKEN=your-token

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_VERCEL_URL=your-app.vercel.app