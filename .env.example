# ===========================================
# NEXUSAI ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ===========================================
# SUPABASE (Required)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Only for server-side, never expose to client

# ===========================================
# AI PROVIDERS
# ===========================================
# Puter (default, no key needed)
NEXT_PUBLIC_PUTER_DOMAIN=puter.app
NEXT_PUBLIC_PUTER_APP_ID=your-app-id

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic/Claude
# ANTHROPIC_API_KEY=sk-ant-...

# Groq
# GROQ_API_KEY=gsk_...

# Gemini
# GEMINI_API_KEY=AIza...

# DeepSeek
# DEEPSEEK_API_KEY=sk-...

# OpenRouter
# OPENROUTER_API_KEY=sk-or-...

# NVIDIA
# NVIDIA_API_KEY=nvd-...

# ===========================================
# MEDIA PROVIDERS
# ===========================================
# ElevenLabs (Voice)
# ELEVENLABS_API_KEY=your-key
# ELEVENLABS_VOICE_ID=your-voice-id

# LTX Video
# NEXT_PUBLIC_LTX_ENDPOINT=fal-ai/ltx-2.3/text-to-video/fast
# NEXT_PUBLIC_LTX_OPEN_ENDPOINT=your-endpoint

# Fal AI Image
# FAL_API_KEY=your-key

# ===========================================
# SOCIAL MEDIA PUBLISHING
# ===========================================
# Ayrshare (multi-platform publishing)
# AYRSHARE_API_KEY=your-key

# ===========================================
# AUTOMATION
# ===========================================
# N8N Workflow Automation
# N8N_URL=http://localhost
# N8N_PORT=5678
# N8N_API_KEY=your-key
# N8N_BRIDGE_SECRET=your-secret

# ===========================================
# EXTERNAL APIs
# ===========================================
# MediaStack (news/content)
# REACT_APP_MEDIASTACK_KEY=your-key

# SerpStack (search)
# REACT_APP_SERPSTACK_KEY=your-key

# UserStack (user agent)
# REACT_APP_USERSTACK_KEY=your-key

# IPStack (geolocation)
# REACT_APP_IPSTACK_KEY=your-key

# NumVerify (phone validation)
# REACT_APP_NUMVERIFY_KEY=your-key

# ===========================================
# WORKER & JOBS
# ===========================================
# WORKER_SECRET=your-secret-token

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000