# ===========================================
# NEXUSAI ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ===========================================
# SUPABASE (Required for auth)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# PUTER (Default AI - no key needed)
# ===========================================
NEXT_PUBLIC_PUTER_DOMAIN=puter.app

# ===========================================
# AI PROVIDERS (Optional - at least one required for content generation)
# ===========================================
# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic/Claude
# ANTHROPIC_API_KEY=sk-ant-...

# Groq (fast inference)
# GROQ_API_KEY=gsk_...

# Gemini (Google)
# GEMINI_API_KEY=AIza...

# ===========================================
# MEDIA PROVIDERS (Optional)
# ===========================================
# ElevenLabs (Voice generation)
# ELEVENLABS_API_KEY=your-key
# ELEVENLABS_VOICE_ID=your-voice-id

# ===========================================
# AUTOMATION (Optional)
# ===========================================
# N8N Workflow
# N8N_URL=http://localhost
# N8N_PORT=5678
# N8N_API_KEY=your-key
# N8N_BRIDGE_SECRET=your-secret

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000